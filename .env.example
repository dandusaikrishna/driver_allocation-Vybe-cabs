PORT=3000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=vybe
DB_PASSWORD=vybe_secret
DB_DATABASE=vybe_cabs

REDIS_HOST=localhost
REDIS_PORT=6379

# How many nearby drivers to notify per allocation round
DRIVERS_PER_ROUND=3

# Seconds to wait for a driver to accept before retrying
ALLOCATION_TIMEOUT_SECONDS=10

# Maximum allocation rounds before marking ride as TIMEOUT
MAX_ALLOCATION_ROUNDS=3

# Geo search radius in kilometres
GEO_SEARCH_RADIUS_KM=5
